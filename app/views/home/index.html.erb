<section class="hero" style="background-image: url('<%= asset_path("hero-image.jpg") %>');">
  <div class="hero-content">
    <p>Winnipeg Based</p>
    <h1>The Outdoors Is Waiting for You</h1>
    <%= link_to "Shop All", "#products", class: "hero-button" %>
  </div>
</section>

<section class="product-section" id="products">
  <div class="section-heading">
    <p>Explore Superex</p>
    <h2>Built for Life Outside</h2>
  </div>

  <div class="product-toolbar">
    <details class="category-dropdown">
      <summary>
        <% if @selected_category %>
          <%= @selected_category.name %>
        <% else %>
          Shop by Category
        <% end %>
      </summary>

      <div class="category-dropdown-menu">
        <%= link_to "All Products", root_path(anchor: "products") %>

        <% @categories.each do |category| %>
          <%= link_to category.name,
                      root_path(category_id: category.id, anchor: "products") %>
        <% end %>
      </div>
    </details>

    <p class="product-count">
      <%= pluralize(@products.count, "product") %>
    </p>
  </div>

  <div class="product-grid">
    <% @products.each do |product| %>
      <%= render "products/product_card", product: product %>
    <% end %>
  </div>
</section>