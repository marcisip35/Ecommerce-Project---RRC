<% content_for :title, @product.name %>

<section class="product-details">
  <div class="product-details-image">
    <% if @product.image.attached? %>
      <%= image_tag @product.image, alt: @product.name %>
    <% else %>
      <div class="product-details-missing-image">
        <span>Image coming soon</span>
      </div>
    <% end %>
  </div>

  <div class="product-details-info">
    <h1><%= @product.name %></h1>

    <p class="product-description">
      <%= @product.description %>
    </p>

    <div class="product-details-price">
      <% if @product.on_sale && @product.sale_price.present? %>
        <span class="details-sale-price">
          <%= number_to_currency(@product.sale_price) %>
        </span>

        <span class="details-old-price">
          <%= number_to_currency(@product.price) %>
        </span>
      <% else %>
        <span><%= number_to_currency(@product.price) %></span>
      <% end %>
    </div>

    <div class="product-details-meta">
      <p class="product-details-category">
        <%= @product.categories.map(&:name).join(", ") %>
      </p>

      <p class="stock-message">
        <% if @product.stock_quantity > 0 %>
          In stock
        <% else %>
          Out of stock
        <% end %>
      </p>
    </div>

    <button type="button" class="add-cart-button">
      Add to Cart
    </button>

    <%= link_to "Back to Products",
                root_path(anchor: "products"),
                class: "back-link" %>
  </div>
</section>